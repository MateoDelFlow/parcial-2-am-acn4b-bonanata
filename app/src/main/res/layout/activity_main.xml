<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".MainActivity">

    <!-- Logo Superior Izquierda -->
    <ImageView
        android:id="@+id/iv_top_logo"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_top_logo"
        app:tint="#7F00FF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Nombre de Marca Superior Derecha -->
    <TextView
        android:id="@+id/tv_brand_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CashFlow"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Círculo del Chanchito (Icono Principal) -->
    <ImageView
        android:id="@+id/iv_main_icon"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="40dp"
        android:padding="20dp"
        android:src="@drawable/ic_piggy_bank"
        android:background="@drawable/ic_launcher_background"
        android:backgroundTint="#7F00FF"
        app:layout_constraintTop_toBottomOf="@id/iv_top_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Título de la Sección -->
    <TextView
        android:id="@+id/tv_titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gastos"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/iv_main_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Campo: Descripción -->
    <EditText
        android:id="@+id/et_descripcion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:hint="@string/hint_descripcion"
        android:inputType="textCapSentences"
        app:layout_constraintTop_toBottomOf="@id/tv_titulo"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Campo: Monto -->
    <EditText
        android:id="@+id/et_monto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:hint="@string/hint_monto"
        android:inputType="numberDecimal"
        app:layout_constraintTop_toBottomOf="@id/et_descripcion"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Botón: Cargar -->
    <Button
        android:id="@+id/btn_guardar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/btn_cargar"
        android:backgroundTint="#7F00FF"
        app:layout_constraintTop_toBottomOf="@id/et_monto"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Display de Total -->
    <TextView
        android:id="@+id/tv_total_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/label_total"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#7F00FF"
        app:layout_constraintTop_toBottomOf="@id/btn_guardar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Título Gastos Recientes -->
    <TextView
        android:id="@+id/tv_recientes_titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Gastos Recientes"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tv_total_display"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Contenedor Dinámico con Scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_recientes_titulo"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/container_gastos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>